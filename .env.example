# NIX TRADES - Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git (it is in .gitignore)

# ==================== TELEGRAM ====================
# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ==================== SUPABASE DATABASE ====================
# Get from: Supabase Dashboard -> Settings -> API
# Use the PROJECT URL (looks like https://xxxxx.supabase.co)
SUPABASE_URL=https://your-project-id.supabase.co

# IMPORTANT: Use the service_role key, NOT the anon key
# Get from: Supabase Dashboard -> Settings -> API -> service_role (secret)
SUPABASE_KEY=your_supabase_service_role_key_here

# ==================== ENCRYPTION ====================
# Generate a key: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# KEEP THIS SECRET - if you lose it, all stored MT5 passwords become unreadable
ENCRYPTION_KEY=your_fernet_encryption_key_here

# ==================== MT5 WORKER SERVICE ====================
# The URL of your Windows VPS running mt5_worker.py
# Example: http://203.0.113.50:8000 (use your Windows VPS IP address)
# The Windows machine must be accessible from your bot server
MT5_WORKER_URL=http://YOUR_WINDOWS_VPS_IP:8000

# This key authenticates the bot to the MT5 worker
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
# MUST MATCH the MT5_WORKER_API_KEY set on your Windows VPS
MT5_WORKER_API_KEY=your_mt5_worker_api_key_here

# ==================== OPTIONAL ====================
# News API key from newsapi.org (optional - bot works without it)
# Free tier: 100 requests/day
NEWS_API_KEY=

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

ADMIN_USER_IDS=your_telegram_user_id_here # Comma-separated list of Telegram user IDs that can use admin commands (like /download)
METAAPI_TOKEN=

PAYSTACK_SECRET_KEY=your_paystack_secret_key_here
PAYSTACK_PUBLIC_KEY=your_paystack_public_key_here
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
STRIPE_PRICE_BASIC=price_xxxxx
STRIPE_PRICE_PRO=price_xxxxx
BYBIT_API_KEY=your_bybit_key_here
BYBIT_API_SECRET=your_bybit_secret_here
PAYMENT_CALLBACK_URL=https://your-server-ip/webhooks/paystack
PAYMENT_SUCCESS_URL=your bot's Telegram link or website URL here
PAYMENT_CANCEL_URL=your bot's Telegram link or website URL here
GOOGLE_API_KEY=paste_your_key_here
GROQ_API_KEY=paste_your_gsk_key_here


